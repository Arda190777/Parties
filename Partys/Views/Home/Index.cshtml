@model IEnumerable<Partys.Models.Invitation>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Manage your parties and invitations with this ASP.NET Core app.</p>
</div>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <p class="mt-3">
        You are logged in as <strong>@User.Identity.Name</strong>.
    </p>
}

@if (Model != null && Model.Any())
{
    <div class="alert alert-info mt-4">
        <h4>You have invitations!</h4>
        <table class="table">
            <tr>
                <th>Party</th>
                <th>Date</th>
                <th>Location</th>
                <th>Actions</th>
            </tr>
            @foreach (var invite in Model)
            {
                <tr>
                    <td>@invite.Party.Description</td>
                    <td>@invite.Party.EventDate.ToShortDateString()</td>
                    <td>@invite.Party.Location</td>
                    <td>
                        <a asp-controller="Invitations" asp-action="Respond"
                           asp-route-id="@invite.Id" asp-route-response="accept"
                           class="btn btn-success btn-sm">Accept</a>

                        <a asp-controller="Invitations" asp-action="Respond"
                           asp-route-id="@invite.Id" asp-route-response="decline"
                           class="btn btn-danger btn-sm">Decline</a>
                    </td>
                </tr>
            }
        </table>
    </div>
}