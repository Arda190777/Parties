@model Partys.Models.Party

@{
    ViewData["Title"] = "Delete Party";
}

<h1>Delete Party</h1>

<h3>Are you sure you want to delete this party?</h3>

<div class="card p-3 mt-3">
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Event Date:</strong> @Model.EventDate.ToString("MMMM dd, yyyy")</p>
    <p><strong>Location:</strong> @Model.Location</p>
</div>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-3">
    @Html.AntiForgeryToken() 

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
